fn print_output(output: codonsplice_core::VmOutput) {
    use codonsplice_core::vm::record_to_json;
    match output {
        codonsplice_core::VmOutput::Rows(rows) | codonsplice_core::VmOutput::Records(rows) => {
            for row in rows {
                println!("{}", record_to_json(&row));
            }
        }
        codonsplice_core::VmOutput::Text(s) => println!("{s}"),
        codonsplice_core::VmOutput::Ready(_) => {}
    }
}
