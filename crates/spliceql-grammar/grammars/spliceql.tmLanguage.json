{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SpliceQL",
  "scopeName": "source.spq",
  "fileTypes": ["spq"],
  "patterns": [
    { "include": "#shebang" },
    { "include": "#directives" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#genomic" },
    { "include": "#formats" },
    { "include": "#variables" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#comparison" },
    { "include": "#arithmetic" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "shebang": {
      "match": "^#!.*$",
      "name": "comment.line.shebang.spliceql"
    },
    "directives": {
      "match": "^--\\s*(@\\w+)(:.*)$",
      "name": "meta.directive.spliceql",
      "captures": {
        "1": { "name": "keyword.other.directive.spliceql" },
        "2": { "name": "string.unquoted.directive-value.spliceql" }
      }
    },
    "comments": {
      "match": "--.*$",
      "name": "comment.line.double-dash.spliceql"
    },
    "keywords": {
      "match": "\\b(?i:FROM|SELECT|WHERE|CALL|WITH|INTO|FILTER|ORDER|BY|LIMIT|AND|OR|NOT|AS|ASC|DESC)\\b",
      "name": "keyword.control.spliceql"
    },
    "genomic": {
      "match": "\\b(?i:variants|cnv|coverage|reads|header)\\b",
      "name": "keyword.other.genomic.spliceql"
    },
    "formats": {
      "match": "\\b(?i:bam|vcf|fasta|bed|cram)\\b",
      "name": "support.type.format.spliceql"
    },
    "variables": {
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.other.spliceql"
    },
    "strings": {
      "name": "string.quoted.double.spliceql",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.spliceql"
        }
      ]
    },
    "numbers": {
      "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
      "name": "constant.numeric.spliceql"
    },
    "booleans": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.spliceql"
    },
    "comparison": {
      "match": "!=|<=|>=|<|>|=",
      "name": "keyword.operator.comparison.spliceql"
    },
    "arithmetic": {
      "match": "[+\\-*/]",
      "name": "keyword.operator.arithmetic.spliceql"
    },
    "identifiers": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.field.spliceql"
    }
  }
}
